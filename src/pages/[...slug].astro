---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const seoSlugs = [
    'craving-imperfection-d4e239a44743',
    'india-the-enigma-64d045d8f366',
    'the-empathy-deficit-25c82c4460e7',
    'to-my-freshman-self-bd53aa9b8ddb',
    'why-exams-waste-everyones-time-819332418297',
    'a-list-of-top-penn-classes-b69d73507365',
    'the-hedonic-treadmill-our-happiness-resting-point-74a25f22421a',
    'a-few-strategies-on-dealing-with-tough-days-472d7f6c2317',
  ];
  const posts = await getCollection('writing');
  return posts
    .filter((post) => seoSlugs.includes(post.id))
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} — Yash Kothari`} description={post.data.description}>
  <article>
    <header class="mb-10">
      <h1 class="text-xl font-sans font-light leading-tight">{post.data.title}</h1>
      <time class="text-sm text-midnight/50 mt-2 block" datetime={post.data.date.toISOString()}>
        {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
