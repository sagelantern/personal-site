---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout title="Writing — Yash Kothari" description="Blog posts by Yash Kothari.">
  <h1 class="font-serif text-3xl font-bold mb-12">Writing</h1>
  <ul class="space-y-10">
    {posts.map((post) => (
      <li>
        <a href={`/writing/${post.id}`} class="group block">
          <h2 class="font-serif text-xl font-bold group-hover:text-warm-800 transition-colors">
            {post.data.title}
          </h2>
          <time class="text-sm text-warm-800/50 mt-1 block" datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <p class="text-warm-800/70 mt-2 leading-relaxed">{post.data.description}</p>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
