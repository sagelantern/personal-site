---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Yash Kothari" isHome>
  <div class="mt-12">
    <!-- Hero -->
    <h1 class="font-display text-3xl sm:text-4xl font-bold tracking-tight mb-6">Yash Kothari</h1>
    <p class="font-serif text-monsoon-ink/90 leading-[1.75] mb-12 max-w-[600px]">
      I'm a founder and investor in New York. Indian-born, Wharton-educated, two startups and a decade in tech. Right now most of my time goes to meditation, family, and writing. I run <a href="https://kindredapp.co" class="link">Kindred</a> and invest through <a href="https://pioneerfund.vc" class="link">Pioneer Fund</a>, but those take up about two days a week. The rest is practice.
    </p>

    <!-- Right Now aside -->
    <aside class="border-l-2 border-marigold pl-4 mb-16 max-w-[480px]">
      <p class="font-display italic text-sm text-river-slate leading-relaxed">
        Right now &mdash;<br />
        Reading Red Rising (Pierce Brown)<br />
        Training for nothing in particular, 15 miles a week<br />
        Second kid arriving August<br />
        Building an AI mindfulness tool nobody asked for
      </p>
    </aside>

    <!-- Work -->
    <section class="mb-14">
      <h2 class="section-heading">Work</h2>
      <ul class="space-y-3">
        <li>
          <a href="https://kindredapp.co" class="link">Kindred</a>
          <span class="text-monsoon-ink/70 font-serif"> &mdash; AI performance management (CEO)</span>
        </li>
        <li>
          <a href="https://pioneerfund.vc" class="link">Pioneer Fund</a>
          <span class="text-monsoon-ink/70 font-serif"> &mdash; early-stage VC (Senior VP)</span>
        </li>
        <li>
          <span>Stay Nivas</span>
          <span class="text-monsoon-ink/70 font-serif"> &mdash; hotel reviews through feeling, not amenities</span>
        </li>
        <li>
          <a href="https://covaidindia.org" class="link">CovAID India</a>
          <span class="text-monsoon-ink/70 font-serif"> &mdash; pandemic charity assessment, 2020&ndash;21 (with brother Aryan)</span>
        </li>
      </ul>
    </section>

    <hr class="border-sandstone border-t mb-14" />

    <!-- Writing -->
    <section class="mb-14">
      <h2 class="section-heading">Writing</h2>
      <p class="font-serif">
        <a href="/writing" class="link">Essays from 2015 to now &rarr;</a>
      </p>
      <p class="text-monsoon-ink/60 font-serif text-sm mt-1">Mostly about meaning, imperfection, and India.</p>
    </section>

    <hr class="border-sandstone border-t mb-14" />

    <!-- Family -->
    <section class="mb-14">
      <h2 class="section-heading">Family</h2>
      <p class="font-serif">
        <a href="/family" class="link">Annual family letters &rarr;</a>
      </p>
    </section>

    <hr class="border-sandstone border-t mb-14" />

    <!-- Around the web -->
    <section class="mb-14">
      <h2 class="section-heading">Around the web</h2>
      <ul class="space-y-3">
        <li>
          <a href="https://linkedin.com/in/kothariy" class="link">LinkedIn</a>
          <span class="text-monsoon-ink/70 font-serif"> &mdash; linkedin.com/in/kothariy</span>
        </li>
        <li>
          <a href="https://twitter.com/yaborohy" class="link">Twitter</a>
          <span class="text-monsoon-ink/70 font-serif"> &mdash; @yaborohy</span>
        </li>
      </ul>
    </section>
  </div>
</BaseLayout>
