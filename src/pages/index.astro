---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Yash Kothari">
  <div class="mt-12">
    <h1 class="font-serif text-4xl font-bold leading-tight mb-8">Yash Kothari.</h1>
    <p class="text-lg leading-relaxed text-warm-800 mb-6">
      Builder, father, student of life.<br />Based in New York.
    </p>
    <div class="flex gap-6 text-sm mt-10">
      <a href="/writing" class="underline underline-offset-4 decoration-warm-800/30 hover:decoration-warm-800 transition-colors">
        Writing
      </a>
      <a href="/family" class="underline underline-offset-4 decoration-warm-800/30 hover:decoration-warm-800 transition-colors">
        Family updates
      </a>
    </div>
  </div>
</BaseLayout>
