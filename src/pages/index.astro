---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Yash Kothari" isHome>
  <div class="mt-12">
    <h1 class="text-2xl font-light font-sans mb-3">Yash Kothari</h1>
    <p class="font-serif italic text-midnight/90 leading-relaxed mb-6">
      Father, builder, meditator. Practicing presence in New York.
    </p>
    <p class="font-serif text-midnight/90 leading-relaxed mb-16">
      CEO of <a href="https://kindredapp.co" class="link">Kindred</a>. Senior VP at <a href="https://pioneerfund.vc" class="link">Pioneer Fund</a>. Wharton undergrad. YC alum.
    </p>

    <section class="mb-14">
      <h2 class="section-heading">Projects</h2>
      <ul class="space-y-3">
        <li>
          <a href="https://kindredapp.co" class="link">Kindred</a>
          <span class="text-midnight/70 font-serif"> — AI-powered continuous performance management</span>
        </li>
        <li>
          <a href="https://pioneerfund.vc" class="link">Pioneer Fund</a>
          <span class="text-midnight/70 font-serif"> — Early-stage venture capital</span>
        </li>
        <li>
          <a href="https://covaidindia.org" class="link">CovAID India</a>
          <span class="text-midnight/70 font-serif"> — Pandemic charity assessment (2020–2021, with brother Aryan)</span>
        </li>
        <li>
          <span>The Portrait Project</span>
          <span class="text-midnight/70 font-serif"> — Custom hand-drawn portraits, a project with Shivantika (2020)</span>
        </li>
      </ul>
    </section>

    <hr class="border-sage border-t mb-14" />

    <section class="mb-14">
      <h2 class="section-heading">Writing</h2>
      <p class="font-serif"><a href="/writing" class="link">Blog and essays &rarr;</a></p>
    </section>

    <hr class="border-sage border-t mb-14" />

    <section class="mb-14">
      <h2 class="section-heading">Family</h2>
      <p class="font-serif"><a href="/family" class="link">Annual family updates &rarr;</a></p>
    </section>

    <hr class="border-sage border-t mb-14" />

    <section class="mb-14">
      <h2 class="section-heading">Around the web</h2>
      <ul class="space-y-3">
        <li>
          <a href="https://linkedin.com/in/kothariy" class="link">LinkedIn</a>
          <span class="text-midnight/70 font-serif"> — linkedin.com/in/kothariy</span>
        </li>
        <li>
          <a href="https://twitter.com/yaborohy" class="link">Twitter</a>
          <span class="text-midnight/70 font-serif"> — @yaborohy</span>
        </li>
      </ul>
    </section>
  </div>
</BaseLayout>
