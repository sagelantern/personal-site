---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Yash Kothari" isHome>
  <div class="mt-12">
    <!-- Hero -->
    <h1 class="font-display text-3xl sm:text-4xl font-bold tracking-tight mb-6">Yash Kothari</h1>
    <p class="font-serif text-monsoon-ink/90 leading-[1.75] mb-12 max-w-[600px]">
      I'm a founder and investor in New York. Wharton-educated, two startups and a decade in tech. I run <a href="https://trykindred.com" class="link">Kindred</a> and invest through <a href="https://pioneerfund.vc" class="link">Pioneer Fund</a>. Most of my time goes to meditation, family, and writing.
    </p>

    <!-- Work -->
    <section class="mb-14">
      <h2 class="section-heading">Work</h2>
      <ul class="space-y-3">
        <li>
          <a href="https://trykindred.com" class="link">Kindred</a>
          <span class="text-monsoon-ink/70 font-serif"> &mdash; AI performance management (CEO)</span>
        </li>
        <li>
          <a href="https://pioneerfund.vc" class="link">Pioneer Fund</a>
          <span class="text-monsoon-ink/70 font-serif"> &mdash; early-stage VC (Senior VP)</span>
        </li>
        <li>
          <a href="https://staynivas.com" class="link">Stay Nivas</a>
          <span class="text-monsoon-ink/70 font-serif"> &mdash; hotel reviews through feeling, not amenities</span>
        </li>
      </ul>
    </section>

    <hr class="border-sandstone border-t mb-14" />

    <!-- Writing -->
    <section class="mb-14">
      <h2 class="section-heading">Writing</h2>
      <p class="font-serif">
        <a href="/writing" class="link">Essays from 2015 to now &rarr;</a>
      </p>
      <p class="text-monsoon-ink/60 font-serif text-sm mt-1">Mostly about meaning, imperfection, and India.</p>
    </section>

    <hr class="border-sandstone border-t mb-14" />

    <!-- Rituals -->
    <section class="mb-14">
      <h2 class="section-heading">Rituals</h2>
      <p class="font-serif text-monsoon-ink/90 leading-[1.75] mb-6 max-w-[600px]">
        I center my life around a set of daily and weekly rituals. They aren&rsquo;t productivity hacks &mdash; they&rsquo;re how I stay grounded, present, and intentional about the life I&rsquo;m building.
      </p>
      <p class="text-monsoon-ink/60 font-serif text-sm mb-2 italic">Daily</p>
      <ul class="space-y-2 mb-6">
        <li class="font-serif text-monsoon-ink/90">One-hour morning meditation (Vipassana)</li>
        <li class="font-serif text-monsoon-ink/90">15-minute afternoon sit</li>
        <li class="font-serif text-monsoon-ink/90">Exercise &mdash; zone 2 runs, ~15 miles a week</li>
        <li class="font-serif text-monsoon-ink/90">Fiction before bed</li>
        <li class="font-serif text-monsoon-ink/90">Devices away in the evening</li>
      </ul>
      <p class="text-monsoon-ink/60 font-serif text-sm mb-2 italic">Weekly</p>
      <ul class="space-y-2">
        <li class="font-serif text-monsoon-ink/90">Date night with Shivantika</li>
        <li class="font-serif text-monsoon-ink/90">Sohum fun day (dedicated time with my son)</li>
        <li class="font-serif text-monsoon-ink/90">Weekly review and planning</li>
        <li class="font-serif text-monsoon-ink/90">Community sit (Thursdays)</li>
      </ul>
    </section>

    <hr class="border-sandstone border-t mb-14" />

    <!-- Around the web -->
    <section class="mb-14">
      <h2 class="section-heading">Around the web</h2>
      <ul class="space-y-3">
        <li>
          <a href="https://linkedin.com/in/kothariy" class="link">LinkedIn</a>
          <span class="text-monsoon-ink/70 font-serif"> &mdash; linkedin.com/in/kothariy</span>
        </li>
        <li>
          <a href="#" class="link" id="email-link">Email</a>
          <span class="text-monsoon-ink/70 font-serif" id="email-text"> &mdash; </span>
          <script>
            (function() {
              var u = 'kothari.s.yash';
              var d = 'gmail.com';
              var e = u + '@' + d;
              var link = document.getElementById('email-link');
              var text = document.getElementById('email-text');
              link.href = 'mai' + 'lto:' + e;
              text.textContent = ' — ' + e;
            })();
          </script>
        </li>
      </ul>
    </section>
  </div>
</BaseLayout>
