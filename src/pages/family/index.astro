---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const updates = (await getCollection('family')).sort(
  (a, b) => b.data.year - a.data.year
);
---

<BaseLayout title="Family — Yash Kothari" description="Annual family updates from the Kotharis.">
  <h1 class="font-serif text-3xl font-bold mb-12">Family Updates</h1>
  <div class="space-y-16">
    {updates.map(async (update) => {
      const { Content } = await render(update);
      return (
        <article>
          <h2 class="font-serif text-2xl font-bold mb-1">{update.data.title}</h2>
          <span class="text-sm text-warm-800/50 block mb-4">{update.data.year}</span>
          <div class="prose">
            <Content />
          </div>
        </article>
      );
    })}
  </div>
</BaseLayout>
