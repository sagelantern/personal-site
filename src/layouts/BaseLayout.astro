---
interface Props {
  title: string;
  description?: string;
  isHome?: boolean;
}

const { title, description = 'Yash Kothari — Builder, father, student of life.', isHome = false } = Astro.props;

import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Yash Kothari" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-warm-50 text-warm-900 font-sans antialiased">
    <div class="max-w-[680px] mx-auto px-6 py-12 min-h-screen flex flex-col">
      {!isHome && (
        <nav class="mb-12">
          <a href="/" class="text-sm text-warm-800/60 hover:text-warm-900 transition-colors">
            &larr; Yash Kothari
          </a>
        </nav>
      )}

      <main class="flex-1">
        <slot />
      </main>

      <footer class="mt-24 pt-8 border-t border-warm-100 text-sm text-warm-800/40">
        &copy; {new Date().getFullYear()} Yash Kothari
      </footer>
    </div>
  </body>
</html>
